# AWS
AWS_REGION=us-east-1

# Where x402 payments land. THIS IS NOT THE AGENT WALLET — it is the API
# operator's wallet (your wallet for the demo). The agent pays this address.
RECIPIENT_WALLET=0x0000000000000000000000000000000000000000

# Price per call in USDC.
PRICE_USDC=0.01

# Network and token
NETWORK=base-sepolia
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
