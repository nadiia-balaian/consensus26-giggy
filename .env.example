# Top-level reference values shared across subprojects.
# Each subproject has its own .env.example with the values it actually uses.
# This file is for human reference only — nothing reads it directly.

# ---------- Network ----------
BASE_SEPOLIA_RPC=https://sepolia.base.org
CHAIN_ID=84532

# Base Sepolia USDC (testnet). Verify against:
# https://docs.base.org/base-chain/network-information/base-sepolia-testnet
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ---------- Deployed addresses (filled in after each deploy step) ----------
# 1. Contracts deploy first
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# 2. x402-api deploy → its public URL
X402_API_URL=https://example.execute-api.us-east-1.amazonaws.com

# 3. backend deploy → its public URL
BACKEND_URL=https://example.execute-api.us-east-1.amazonaws.com

# 4. frontend deploy
FRONTEND_URL=https://example.vercel.app
