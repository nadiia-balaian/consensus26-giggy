# AWS
AWS_REGION=us-east-1

# Base Sepolia
BASE_SEPOLIA_RPC=https://sepolia.base.org
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# x402-api endpoint (deployed in Phase 2)
X402_API_URL=https://example.execute-api.us-east-1.amazonaws.com

# Bedrock — confirm the exact model ID for your region in the AWS console
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# Coinbase Developer Platform — server-managed agent wallet
CDP_API_KEY_NAME=
CDP_API_KEY_SECRET=
AGENT_WALLET_ID=

# Set to "false" while iterating locally to disable the EventBridge cron
AGENT_CRON_ENABLED=true
